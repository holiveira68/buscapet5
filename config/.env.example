# ═══════════════════════════════════════════════
# BUSCAPET — Variáveis de Ambiente
# ═══════════════════════════════════════════════
# 1. Copie este arquivo para a pasta backend/:
#    cp config/.env.example backend/.env
#
# 2. Preencha com seus dados reais
# 3. NUNCA suba o .env para o git (já está no .gitignore)
# ═══════════════════════════════════════════════

# ── Servidor ────────────────────────────────────
PORT=3001

# ── Banco de Dados MySQL ─────────────────────────
DB_HOST=localhost       # endereço do servidor MySQL
DB_USER=root            # usuário do banco
DB_PASS=sua_senha_aqui  # senha do banco
DB_NAME=buscapet        # nome do banco (criado pelo schema.sql)
DB_PORT=3306            # porta padrão do MySQL

# ── Autenticação JWT ─────────────────────────────
# IMPORTANTE: troque por uma string longa e aleatória em produção!
# Gere uma com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-por-string-longa-e-aleatoria-aqui
JWT_EXPIRES=7d          # tempo de expiração do token (7 dias)

# ── Admin ────────────────────────────────────────
# Chave para o endpoint POST /api/matches/run (forçar full matching)
ADMIN_KEY=buscapet-admin

# ── E-mail (opcional) ────────────────────────────
# Necessário apenas para a função "Recuperar senha"
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seuemail@gmail.com
MAIL_PASS=sua-app-password-do-gmail   # use App Password, não sua senha normal
MAIL_FROM=Buscapet <noreply@buscapet.com>
